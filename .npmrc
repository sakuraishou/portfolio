legacy-peer-deps=true

# --- pnpm 設定 ---
# node_modules を npm 同様のフラット構成にする。
# Next.js の output:'standalone' は依存トレースで node_modules を辿るため、
# pnpm 既定のシンボリックリンク構成だと phantom dependency で取りこぼす恐れがある。
# hoisted にすることで npm 相当の構成になり standalone ビルドの互換性を確保する。
node-linker=hoisted
# peer dependency の不一致をエラーにしない（React 19 等の peer 範囲対策。旧 legacy-peer-deps 相当）
strict-peer-dependencies=false